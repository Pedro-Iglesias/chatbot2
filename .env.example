# ==================== GEMINI API ====================
GEMINI_API_KEY=sua_chave_aqui_aqui

# ==================== BANCO DE DADOS ====================
POSTGRES_DB=chatbot
POSTGRES_USER=chatbot_user
POSTGRES_PASSWORD=chatbot2026

# Configuração para rodar localmente com Docker
DB_HOST=localhost
DB_PORT=5433

# ==================== DJANGO ====================
SECRET_KEY=django-insecure-troque-por-uma-chave-muito-grande-e-secreta-aqui-123456789
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ==================== MODELOS DO GEMINI ====================
# Modelos estáveis recomendados (não altere se não souber)
CHAT_MODEL=gemini-1.5-flash
EMBEDDING_MODEL=models/gemini-embedding-001
TOP_K=5